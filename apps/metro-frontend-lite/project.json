{
  "name": "metro-frontend-lite",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "app",
  "sourceRoot": "apps/metro-frontend-lite/src",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@angular/build:application",
      "outputs": [
        "{options.outputPath}"
      ],
      "options": {
        "baseHref": "/lite/",
        "outputPath": "dist/apps/metro-frontend-lite",
        "browser": "apps/metro-frontend-lite/src/main.ts",
        "tsConfig": "apps/metro-frontend-lite/tsconfig.app.json",
        "inlineStyleLanguage": "scss",
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/metro-frontend-lite/public"
          },
          {
            "glob": "**/*",
            "input": "libs/shared/assets",
            "output": "public/shared"
          }
        ],
        "styles": [
          "apps/metro-frontend-lite/src/styles.scss"
        ],
        "server": "apps/metro-frontend-lite/src/main.server.ts",
        "ssr": {
          "entry": "apps/metro-frontend-lite/src/server.ts"
        },
        "outputMode": "server",
        "security": {
          "allowedHosts": [
            "metro.yudi.com.br"
          ]
        }
      },
      "configurations": {
        "production": {
          "fileReplacements": [
            {
              "replace": "apps/metro-frontend-lite/src/environments/environment.ts",
              "with": "apps/metro-frontend-lite/src/environments/environment.prod.ts"
            }
          ],
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "500kb",
              "maximumError": "1mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "4kb",
              "maximumError": "8kb"
            }
          ],
          "outputHashing": "all",
          "extractLicenses": true,
          "serviceWorker": "apps/metro-frontend-lite/ngsw-config.json"
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "continuous": true,
      "executor": "@angular/build:dev-server",
      "configurations": {
        "production": {
          "buildTarget": "metro-frontend-lite:build:production"
        },
        "development": {
          "buildTarget": "metro-frontend-lite:build:development"
        }
      },
      "defaultConfiguration": "development",
      "dependsOn": [
        "metro-backend:serve"
      ]
    },
    "extract-i18n": {
      "executor": "@angular/build:extract-i18n",
      "options": {
        "buildTarget": "metro-frontend-lite:build"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": [
        "{workspaceRoot}/coverage/{projectRoot}"
      ],
      "options": {
        "jestConfig": "apps/metro-frontend-lite/jest.config.ts",
        "tsConfig": "apps/metro-frontend-lite/tsconfig.spec.json"
      }
    },
    "serve-static": {
      "continuous": true,
      "executor": "@nx/web:file-server",
      "options": {
        "buildTarget": "metro-frontend-lite:build",
        "port": 4200,
        "staticFilePath": "dist/apps/metro-frontend-lite/browser",
        "spa": true
      }
    },
    "storybook": {
      "executor": "@storybook/angular:start-storybook",
      "options": {
        "port": 4400,
        "configDir": "apps/metro-frontend-lite/.storybook",
        "browserTarget": "metro-frontend-lite:build-storybook",
        "compodoc": true,
        "compodocArgs": [
          "-e",
          "json",
          "-d",
          "./apps/metro-frontend-lite/.storybook/compodoc"
        ],
        "styles": [
          "apps/metro-frontend-lite/src/styles.scss"
        ]
      },
      "configurations": {
        "ci": {
          "quiet": true
        }
      }
    },
    "build-storybook": {
      "executor": "@storybook/angular:build-storybook",
      "outputs": [
        "{options.outputDir}"
      ],
      "options": {
        "outputDir": "dist/storybook/metro-frontend-lite",
        "configDir": "apps/metro-frontend-lite/.storybook",
        "browserTarget": "metro-frontend-lite:build-storybook",
        "compodoc": true,
        "compodocArgs": [
          "-e",
          "json",
          "-d",
          "./apps/metro-frontend-lite/.storybook/compodoc"
        ]
      },
      "configurations": {
        "ci": {
          "quiet": true
        }
      }
    },
    "test-storybook": {
      "executor": "nx:run-commands",
      "options": {
        "command": "test-storybook -c apps/metro-frontend-lite/.storybook --url=http://localhost:4400"
      }
    },
    "static-storybook": {
      "executor": "@nx/web:file-server",
      "dependsOn": [
        "build-storybook"
      ],
      "options": {
        "buildTarget": "metro-frontend-lite:build-storybook",
        "staticFilePath": "dist/storybook/metro-frontend-lite",
        "spa": true
      },
      "configurations": {
        "ci": {
          "buildTarget": "metro-frontend-lite:build-storybook:ci"
        }
      }
    }
  }
}