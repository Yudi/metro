{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../dist/out-tsc",
    "types": ["node"],
    "composite": true,
    "declaration": true
  },
  "include": ["src/**/*.ts", "../../libs/shared/**/src/**/*.ts"],
  "exclude": [
    "jest.config.ts",
    "src/test-setup.ts",
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "**/*.stories.ts",
    "**/*.stories.js"
  ]
}
